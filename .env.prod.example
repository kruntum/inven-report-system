# =================================================================
# Docker Environment Variables Configuration for PRODUCTION
# Usage: Copy this file to .env.prod and update sensitive values
# Command: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# =================================================================

# 1. Environment & Domain Settings
NODE_ENV=production
ALLOWED_ORIGINS=https://coco.tummy.cc

# 2. PostgreSQL Database Credentials
POSTGRES_USER=inven_prod_user
POSTGRES_PASSWORD=YourStrongDatabasePassword2026!
POSTGRES_DB=inven_report_db

# 3. MinIO Object Storage Credentials
MINIO_ROOT_USER=minio_prod_admin
MINIO_ROOT_PASSWORD=YourStrongMinioPassword2026!
MINIO_BUCKET=storage-bucket

# 4. JWT Security Key (MUST be strong and unique in production!)
JWT_SECRET=YourSuperStrongProductionJwtSecretKey32CharsOrMore!
JWT_EXPIRES_IN=7d

# 5. Default Seeding Admin Password (Used during initial db:seed-prod)
ADMIN_PASSWORD=YourStrongAdminPassword2026!
