# ----------------------------------------------------
# Production Environment Variables Example for API
# ----------------------------------------------------
NODE_ENV=production
API_PORT=6001

# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://postgres:StrongPasswordHere@postgres:5432/inven_report_db

# Security & Authentication (Required in Production!)
JWT_SECRET=YourSuperStrongProductionJwtSecretKey32CharsOrMore!

# Allowed CORS Origins (Comma separated)
ALLOWED_ORIGINS=https://coco.tummy.cc

# MinIO / S3 Storage Credentials (Optional/If configured)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secure_pass
MINIO_BUCKET=inven-documents
